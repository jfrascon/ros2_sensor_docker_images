# Common runtime scope
NAMESPACE=multisensor
ROBOT_NAME=robot
ROS_DOMAIN_ID=11

# ROS2 logging
RCUTILS_LOGGING_BUFFERED_STREAM=0
RCUTILS_LOGGING_USE_STDOUT=1
RCUTILS_COLORIZED_OUTPUT=1
RCUTILS_CONSOLE_OUTPUT_FORMAT=[{severity} {time}] [{name}]: {message} ({file_name}:L{line_number})

# CycloneDDS shared configuration
CYCLONEDDS_CONFIG_SOURCE=./cyclonedds_config.xml

# Sensor configuration files (host paths)
UM_MODEL=7
UM_PARAMS_FILE=./um7_params.yaml
LIVOX_USER_CONFIG_FILE=./livox_mid360.json
LIVOX_PARAMS_FILE=./livox_mid360.yaml
ROBOSENSE_CONFIG_FILE=./robosense_helios_16p_config.yaml

# Optional ROS discovery variables (uncomment if needed)
# ROS_LOCALHOST_ONLY=1
# ROS_AUTOMATIC_DISCOVERY_RANGE=SUBNET
# ROS_STATIC_PEERS=192.168.1.10;192.168.1.11
